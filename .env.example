# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# PostgreSQL database connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA&connection_limit=LIMIT&pool_timeout=TIMEOUT
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stellaraid?schema=public&connection_limit=10&pool_timeout=20"

# JWT Configuration
# JWT secret key (min 32 characters) - Use a strong random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
# Access token expiration time (e.g., 15m, 1h, 1d)
JWT_ACCESS_TOKEN_EXPIRATION=15m
# Refresh token expiration time (e.g., 7d, 30d)
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Email Verification
# Email verification token expiration time (e.g., 24h, 1d)
EMAIL_VERIFICATION_TOKEN_EXPIRATION=24h

# Email Service Configuration (Optional)
# Email service provider: sendgrid, aws-ses, or smtp
EMAIL_SERVICE=sendgrid
# Email service API key
EMAIL_API_KEY=your-email-api-key-here
# Sender email address
EMAIL_FROM=noreply@stellaraid.com

# Stellar Network
# Stellar network: testnet, public, or futurenet
STELLAR_NETWORK=testnet
# Stellar Horizon API URL (optional - uses default if not provided)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Logging
# Application log level: error, warn, info, debug
LOG_LEVEL=info
